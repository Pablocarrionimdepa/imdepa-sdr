# OpenAI
OPENAI_API_KEY="sua_chave_openai_aqui"
OPENAI_MODEL="gpt-4.1-mini"
OPENAI_TRANSCRIPTION_MODEL="whisper-1"

# FastAPI
HOST="0.0.0.0"
PORT="9096"

# Gallabox API
GALLABOX_API_KEY="your_api_key"
GALLABOX_API_SECRET="your_api_secret"

# Base URL oficial (com /devapi)
GALLABOX_API_BASE_URL="https://server.gallabox.com/devapi"

# Endpoint de envio de WhatsApp
GALLABOX_MESSAGES_PATH="/messages/whatsapp"

# Opcional: use apenas se o webhook de audio trouxer media_id sem URL direta
GALLABOX_MEDIA_DOWNLOAD_PATH="/media/{media_id}"
# Opcional: alternativa com multiplos paths separados por |
GALLABOX_MEDIA_DOWNLOAD_PATHS="https://server.gallabox.com/media/{media_id}|https://server.gallabox.com/messages/media/{media_id}|https://server.gallabox.com/whatsapp/media/{media_id}|/media/{media_id}|/messages/media/{media_id}|/whatsapp/media/{media_id}"

# Fallback de canal, se o webhook nao trouxer channelId
GALLABOX_CHANNEL_ID="your_channel_id"

# Segredo para validar header x-gallabox-signature do webhook
GALLABOX_WEBHOOK_SECRET="your_webhook_secret"

# Resolucao/encerramento de conversa na Gallabox
GALLABOX_ACCOUNT_ID="your_account_id"
GALLABOX_RESOLVE_CONVERSATION_PATH="/accounts/{account_id}/CAMINHO-DE-RESOLVE"
GALLABOX_RESOLVE_CONVERSATION_METHOD="POST"
GALLABOX_RESOLVE_CONVERSATION_BODY="{\"phone\":\"{phone}\",\"channelId\":\"{channel_id}\",\"status\":\"RESOLVED\"}"
