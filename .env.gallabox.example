# OpenAI
OPENAI_API_KEY="sua_chave_openai_aqui"
OPENAI_MODEL="gpt-4.1-mini"

# FastAPI
HOST="0.0.0.0"
PORT="9096"

# Gallabox API
GALLABOX_API_KEY="your_api_key"
GALLABOX_API_SECRET="your_api_secret"

# Base URL oficial (com /devapi)
GALLABOX_API_BASE_URL="https://server.gallabox.com/devapi"

# Endpoint de envio de WhatsApp
GALLABOX_MESSAGES_PATH="/messages/whatsapp"

# Fallback de canal, se o webhook nao trouxer channelId
GALLABOX_CHANNEL_ID="your_channel_id"

# Segredo para validar header x-gallabox-signature do webhook
GALLABOX_WEBHOOK_SECRET="your_webhook_secret"
